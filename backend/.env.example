# ---- App ----
PROJECT_NAME=Labour Connect API
API_V1_PREFIX=/api/v1
ENVIRONMENT=development

# ---- Security ----
SECRET_KEY=change-this-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ---- Database ----
POSTGRES_USER=labour
POSTGRES_PASSWORD=labour
POSTGRES_DB=labour_connect
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- OTP (mock for MVP) ----
# When true, any phone accepts the DEV_OTP_CODE below (no SMS sent).
OTP_MOCK=true
DEV_OTP_CODE=123456
OTP_EXPIRE_MINUTES=5

# ---- Default admin (seeded on first run) ----
FIRST_ADMIN_EMAIL=admin@labourconnect.in
FIRST_ADMIN_PASSWORD=Admin@123
FIRST_ADMIN_NAME=Super Admin

# ---- CORS ----
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
